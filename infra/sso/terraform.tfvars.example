# infra/sso/terraform.tfvars.example
# Copy to terraform.tfvars and fill in real values.
#
# IAM Identity Center facts for this account (286684483345):
#   SSO instance ARN  : arn:aws:sso:::instance/ssoins-7223ba457995e15d
#   Identity Store ID : d-90663e376f
#   SSO home region   : us-east-1  (independent of the us-west-2 workload region)
#
# IMPORTANT: Entra ID provisions only USERS into AWS (not groups). So we create the
# aws-* groups directly in the AWS Identity Store and add the synced users to them.
# Manage group membership here, in Terraform.
#
# Synced users currently available (UserName as it appears in the Identity Store):
#   guberand@guddge.com, brucew@guddge.com, bhanua@guddge.com,
#   sreevatsav@guddge.com, kartikav@guddge.com, maheshg@guddge.com
#
# Convention: group name -> permission set
#   aws-admins      -> AdministratorAccess
#   aws-powerusers  -> PowerUserAccess
#   aws-readonly    -> ReadOnly
#   aws-billing     -> Billing
#   aws-developers  -> Developer

# 1) Define the AWS-managed groups and who belongs in each.
managed_groups = {
  "aws-admins"     = ["sreevatsav@guddge.com"]
  "aws-developers" = ["bhanua@guddge.com"]
  # "aws-readonly"   = ["kartikav@guddge.com"]
  # "aws-billing"    = ["maheshg@guddge.com"]
  # "aws-powerusers" = ["brucew@guddge.com"]
}

# 2) Assign each group to an account + permission set.
managed_group_assignments = [
  {
    group_name     = "aws-admins"
    account_id     = "286684483345"
    permission_set = "AdministratorAccess"
  },
  {
    group_name     = "aws-developers"
    account_id     = "286684483345"
    permission_set = "Developer"
  },
]

# NOTE: An "Amazon Q User" group is already assigned to AdministratorAccess in the
# console (auto-created by Amazon Q, NOT managed here). Review during IAM-user cleanup.

# --- The block below is only for the case where the IdP CAN sync groups (not our case). ---
# account_assignments = [
#   { group_id = "GROUP_ID_FROM_SCIM", account_id = "286684483345", permission_set = "ReadOnly" },
# ]